# ─── Ouroboros / LLM provider ─────────────────────────────────────────────
# The real agent path ("--engine llm") calls an OpenAI-compatible endpoint.
# Copy this file to .env and fill in your own values. NEVER commit .env.
#
# Any OpenAI-compatible gateway works (jet-night router, OpenRouter, a self-hosted vLLM, etc.).
# For the reported MVP metrics we used the model named below via the jet-night router.
LLM_API_BASE=https://router.jet-night.com/api/v1
LLM_API_KEY=
LLM_MODEL=jetnight-pro

# Request tuning (optional — sane defaults are baked into the code)
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# Budget guardrail: stop calling LLM when cumulative cost (USD) exceeds this.
# 0 = no limit. Set for production runs to avoid runaway spend.
LLM_BUDGET_USD=0
# Rough price per 1K tokens for cost logging (0 = no cost estimation).
LLM_PRICE_PER_1K=0

# Local OpenAI-compatible model (vLLM, llama.cpp, Ollama…). If set, takes
# precedence over LLM_API_BASE for the LLM engine; LLM_API_KEY defaults to "local".
LOCAL_LLM_BASE_URL=

# Mock-LLM: set to "1" to run the LLM-engine path deterministically WITHOUT
# network or API key (uses rule-baseline as the mock backend). For tests/CI.
ATHANOR_LLM_MOCK=0

# ─── MCP servers ───────────────────────────────────────────────────────────
# Host/ports the local MCP servers bind to. Defaults match mcp/mcp_config.json.
MCP_HOST=127.0.0.1
MCP_CALENDAR_MAIL_PORT=9901
MCP_TRACKER_REPO_PORT=9902
MCP_TRANSCRIPTS_PORT=9903
MCP_CONFLUENCE_PORT=9904

# Set to "1" to simulate an unavailable transcripts source (used by TB-11).
MCP_TRANSCRIPTS_DOWN=0

# Backend for MCP data sources.
#   live  = real Jira/Bitbucket/Confluence/Google (mail+calendar) via mcp/_backends.py
#           (requires creds below; seed synthetic "Alpha" data via test-instances/seed_*.py).
#   test  = local test-instances/ (real Jira REST v2 / Bitbucket 2.0 /
#           Confluence REST API v1 contracts, offline; calendar/mail → file).
#   file  = anonymized JSON from MCP_CASE_DIR (offline demo). Default for credless setups.
# Per-source overrides: MCP_BACKEND_<SOURCE> (e.g. MCP_BACKEND_PR=bitbucket for real
# Bitbucket on top of "live"). Preset "live": Jira=atlassian, calendar/mail=google,
# confluence=atlassian, pr=file — add MCP_BACKEND_PR=bitbucket for real Bitbucket.
MCP_BACKEND=
# Optional: real Bitbucket Cloud PRs on top of "live" (needs BITBUCKET_* below).
# MCP_BACKEND_PR=bitbucket

# ─── Test instances (MCP_BACKEND=test) ────────────────────────────────────
# URLs of local test instances with real corporate API contracts + synthetic
# "Alpha" data. Change to real Jira/Bitbucket/Confluence URLs for the pilot (same
# adapters in mcp/_backends.py, no code change). See test-instances/README.md.
TEST_JIRA_URL=http://127.0.0.1:9911
TEST_BITBUCKET_URL=http://127.0.0.1:9913
TEST_CONFLUENCE_URL=http://127.0.0.1:9914
TEST_JIRA_PROJECT=ALPHA
TEST_CONFLUENCE_SPACE=ALPHA
TEST_BB_WORKSPACE=athanor
TEST_BB_REPO_SLUG=alpha

# ─── Atlassian Jira (MCP_BACKEND=atlassian) ─────────────────────────
# Real Jira integration (REST API v2, Basic auth: email + API token).
# Create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
# and put it here. NEVER commit these values — .env is in .gitignore.
# The adapter reads only issues labeled JIRA_LABEL (synthetic "Alpha" data),
# not your real project tasks. See test-instances/seed_atlassian.py to seed.
JIRA_URL=https://<your-tenant>.atlassian.net
JIRA_PROJECT=KAN
JIRA_LABEL=alpha-demo
JIRA_EMAIL=
JIRA_API_TOKEN=

# ─── Atlassian Confluence Cloud (MCP_BACKEND_CONFLUENCE=atlassian) ────────
# Real Confluence Cloud integration (REST API v1, Basic auth: email + API token).
# The same Atlassian API token works for Jira and Confluence — you can reuse
# JIRA_EMAIL/JIRA_API_TOKEN above (CONFLUENCE_EMAIL/CONFLUENCE_API_TOKEN take precedence).
# Create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
# The adapter reads only pages labeled CONFLUENCE_LABEL (synthetic "Alpha" data),
# not your real documentation. See test-instances/seed_confluence.py to seed.
CONFLUENCE_URL=https://<your-tenant>.atlassian.net
CONFLUENCE_SPACE=ALPHA
CONFLUENCE_LABEL=alpha-demo
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# ─── Bitbucket Cloud (MCP_BACKEND_PR=bitbucket) ───────────────────────────
# Real Bitbucket Cloud integration (REST API 2.0). App Passwords are deprecated
# (removed 28.07.2026) — use API tokens. Two auth mechanisms (set ONE):
#
# A) Personal API token (any plan, Basic auth: email + token):
#    Create: https://bitbucket.org/account/settings/api-tokens/
#    (avatar → Personal settings → API tokens → Create API token)
#    Username for Basic auth = your Atlassian ACCOUNT EMAIL (not Bitbucket username).
#    Scopes (API token scopes do NOT inherit — request read AND write):
#      read:repository:bitbucket    write:repository:bitbucket
#      read:pullrequest:bitbucket   write:pullrequest:bitbucket
#    CANNOT create repos (POST /repositories is a workspace-admin op) — create the
#    demo repo manually in UI; seed_bitbucket.py then makes branch + PR.
#
# B) Workspace access token (Premium plan, Bearer auth):
#    Create: bitbucket.org → workspace → Settings → Access tokens → Create access token
#    Scopes: repository (read+write+admin), pullrequest (read+write).
#    CAN create repos. Takes precedence over (A) if both set.
#
# 1) Create a DEDICATED demo repo (synthetic "Alpha" data) — not a working repo.
# 2) python test-instances/seed_bitbucket.py  → creates repo (B only) + branch + PR.
# NEVER commit these values — .env is in .gitignore.
# The adapter reads all OPEN pull requests of BITBUCKET_REPO_SLUG (dedicated demo repo).
BITBUCKET_URL=https://api.bitbucket.org/2.0
BITBUCKET_WORKSPACE=
BITBUCKET_REPO_SLUG=
# A) personal API token (Basic auth)
BITBUCKET_EMAIL=
BITBUCKET_API_TOKEN=
# B) workspace access token (Bearer, Premium) — optional, takes precedence
BITBUCKET_WORKSPACE_TOKEN=
# Issue key embedded in the PR summary ("PR по <key>: миграция на ППРБ").
# Default APP-412 (file-demo style). For the combined live demo with Jira,
# set this to your KAN-done key (see results/atlassian_seeded_keys.json).
BITBUCKET_PR_ISSUE_KEY=APP-412


# ─── mail (IMAP) + Calendar (iCal) — MCP_BACKEND_CALENDAR/MAIL=google ──
# Real external mailbox + calendar (Google) — IMAP app password + public iCal.
# Mail:  1) Enable IMAP in mail settings. 2) Enable 2-Step Verification.
#        3) Create an App Password (https://myaccount.google.com/apppasswords) — 16 chars.
# Calendar: 1) Create event "Релиз-синк · Альфа" 03.07 14:00 in Calendar.
#           2) Make the calendar public (Settings → Access permissions → Make public).
#           3) Copy the iCalendar URL (.ics) from Settings → Integrate calendar.
# NEVER commit these values — .env is in .gitignore.
GOOGLE_ACCOUNT=
GOOGLE_APP_PASSWORD=
GOOGLE_ICAL_URL=

# ─── Agent behaviour ──────────────────────────────────────────────────────
# Extraction engine: "llm" (real agent path) or "rule" (offline baseline).
# Without LLM_API_KEY the CLI auto-falls back to mock-LLM for the "llm" engine.
ATHANOR_ENGINE=llm
# Human-in-the-loop: block outbound drafts until a human approves.
ATHANOR_HITL=1
